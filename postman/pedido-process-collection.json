{
  "info": {
    "name": "pedido-process — Saga Orchestration",
    "_postman_id": "pedido-process-saga-v2",
    "description": "Testes automatizados do fluxo Saga no pedido-process (CloudHub 2). Inclui happy path, compensação e validação de contrato.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://agent-network-ingress-gw-sh06qr.qfq181.bra-s1.cloudhub.io",
      "type": "string"
    },
    {
      "key": "sagaId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 — Happy Path (Saga COMPLETED)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Gera customerId aleatório (nunca '1001' que dispara compensação)",
              "const suffix = Math.floor(Math.random() * 8999) + 1000;",
              "pm.collectionVariables.set('dynamicCustomerId', 'CUST-' + suffix);",
              "",
              "const items = ['Laptop', 'Smartphone', 'Tablet', 'Monitor', 'Teclado'];",
              "const item = items[Math.floor(Math.random() * items.length)];",
              "pm.collectionVariables.set('dynamicItem', item);",
              "",
              "const qty = Math.floor(Math.random() * 3) + 1;",
              "const unitPrice = 1299.99;",
              "pm.collectionVariables.set('dynamicQty', qty);",
              "pm.collectionVariables.set('dynamicUnitPrice', unitPrice.toFixed(2));",
              "pm.collectionVariables.set('dynamicTotal', (qty * unitPrice).toFixed(2));",
              "",
              "const zips = ['01310-100', '04538-132', '20040-020', '30112-010'];",
              "const states = ['SP', 'SP', 'RJ', 'MG'];",
              "const cities = ['São Paulo', 'São Paulo', 'Rio de Janeiro', 'Belo Horizonte'];",
              "const idx = Math.floor(Math.random() * zips.length);",
              "pm.collectionVariables.set('dynamicZip', zips[idx]);",
              "pm.collectionVariables.set('dynamicState', states[idx]);",
              "pm.collectionVariables.set('dynamicCity', cities[idx]);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "",
              "pm.test('Content-Type JSON', () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('status = COMPLETED', () => {",
              "    pm.expect(body.status).to.equal('COMPLETED');",
              "});",
              "",
              "pm.test('sagaId presente', () => {",
              "    pm.expect(body.sagaId).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('results contém orderResult, inventoryResult, billingResult', () => {",
              "    pm.expect(body.results).to.have.all.keys('orderResult', 'inventoryResult', 'billingResult');",
              "});",
              "",
              "pm.test('orderResult.status presente', () => {",
              "    pm.expect(body.results.orderResult).to.have.property('status');",
              "});",
              "",
              "pm.test('inventoryResult.reservationId presente', () => {",
              "    pm.expect(body.results.inventoryResult.reservationId).to.match(/^RES-\\d+$/);",
              "});",
              "",
              "pm.test('billingResult.chargeId presente', () => {",
              "    pm.expect(body.results.billingResult.chargeId).to.match(/^CHG-\\d+$/);",
              "});",
              "",
              "// Salva sagaId para consulta no próximo request",
              "pm.collectionVariables.set('sagaId', body.sagaId);",
              "console.log('✅ Happy Path — sagaId:', body.sagaId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/process/process-order",
          "host": ["{{baseUrl}}"],
          "path": ["process", "process-order"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": {\n    \"customerId\": \"{{dynamicCustomerId}}\",\n    \"name\": \"Maria Souza\",\n    \"email\": \"maria@email.com\",\n    \"document\": \"98765432100\"\n  },\n  \"order\": {\n    \"item\": \"{{dynamicItem}}\",\n    \"qty\": {{dynamicQty}},\n    \"unitPrice\": {{dynamicUnitPrice}},\n    \"totalAmount\": {{dynamicTotal}}\n  },\n  \"billing\": {\n    \"paymentMethod\": \"CREDIT_CARD\",\n    \"cardToken\": \"tok_1234567890\"\n  },\n  \"shipping\": {\n    \"address\": \"Rua das Flores, 123\",\n    \"city\": \"{{dynamicCity}}\",\n    \"state\": \"{{dynamicState}}\",\n    \"zipCode\": \"{{dynamicZip}}\"\n  }\n}"
        }
      }
    },
    {
      "name": "02 — Erro Step 2: Estoque (Saga COMPENSATED)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// qty >= 99 → estoque-sys lança INVENTORY:OUT_OF_STOCK",
              "// Pedido já foi criado (Step 1 completo) → compensação: ORDER_CANCELLED",
              "// Estoque nunca chegou a reservar → NÃO há INVENTORY_RELEASED",
              "console.log('⚡ Triggering inventory error via qty=99 → INVENTORY:OUT_OF_STOCK → compensa ORDER');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 500 (compensação ativada)', () => pm.response.to.have.status(500));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('status = COMPENSATED', () => {",
              "    pm.expect(body.status).to.equal('COMPENSATED');",
              "});",
              "",
              "pm.test('sagaId presente', () => {",
              "    pm.expect(body.sagaId).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('error.errorType contém INVENTORY', () => {",
              "    pm.expect(body.error.errorType).to.include('INVENTORY');",
              "});",
              "",
              "pm.test('compensationActions inclui ORDER_CANCELLED', () => {",
              "    pm.expect(body.compensationActions).to.include('ORDER_CANCELLED');",
              "});",
              "",
              "pm.test('NÃO inclui INVENTORY_RELEASED (estoque nunca reservou)', () => {",
              "    pm.expect(body.compensationActions).to.not.include('INVENTORY_RELEASED');",
              "});",
              "",
              "pm.test('NÃO inclui BILLING_COMPENSATED (fatura nunca cobrou)', () => {",
              "    pm.expect(body.compensationActions).to.not.include('BILLING_COMPENSATED');",
              "});",
              "",
              "pm.collectionVariables.set('sagaId', body.sagaId);",
              "console.log('🔄 Compensação Estoque — sagaId:', body.sagaId, '| actions:', body.compensationActions);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/process/process-order",
          "host": ["{{baseUrl}}"],
          "path": ["process", "process-order"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": {\n    \"customerId\": \"CUST-2002\",\n    \"name\": \"Pedro Lima\",\n    \"email\": \"pedro@email.com\",\n    \"document\": \"11122233344\"\n  },\n  \"order\": {\n    \"item\": \"Laptop\",\n    \"qty\": 99,\n    \"unitPrice\": 2599.99,\n    \"totalAmount\": 257399.01\n  },\n  \"billing\": {\n    \"paymentMethod\": \"CREDIT_CARD\",\n    \"cardToken\": \"tok_1234567890\"\n  },\n  \"shipping\": {\n    \"address\": \"Av. Paulista, 1000\",\n    \"city\": \"Sao Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01310-100\"\n  }\n}"
        }
      }
    },
    {
      "name": "03 — Erro Step 3: Fatura (Saga COMPENSATED)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// customerId '1001' → Pedido retorna orderId 'ORD-555'",
              "// Fatura detecta ORD-555 e lança BILLING:PAYMENT_FAILED",
              "// Compensação: INVENTORY_RELEASED + ORDER_CANCELLED",
              "console.log('⚡ Triggering compensation via customerId=1001 → orderId=ORD-555 → Fatura 500');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 500 (compensação ativada)', () => pm.response.to.have.status(500));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('status = COMPENSATED', () => {",
              "    pm.expect(body.status).to.equal('COMPENSATED');",
              "});",
              "",
              "pm.test('sagaId presente', () => {",
              "    pm.expect(body.sagaId).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('error.errorType contém BILLING', () => {",
              "    pm.expect(body.error.errorType).to.include('BILLING');",
              "});",
              "",
              "pm.test('compensationActions inclui INVENTORY_RELEASED', () => {",
              "    pm.expect(body.compensationActions).to.include('INVENTORY_RELEASED');",
              "});",
              "",
              "pm.test('compensationActions inclui ORDER_CANCELLED', () => {",
              "    pm.expect(body.compensationActions).to.include('ORDER_CANCELLED');",
              "});",
              "",
              "pm.test('NÃO inclui BILLING_COMPENSATED (Fatura falhou antes de ser registrada)', () => {",
              "    pm.expect(body.compensationActions).to.not.include('BILLING_COMPENSATED');",
              "});",
              "",
              "pm.collectionVariables.set('sagaId', body.sagaId);",
              "console.log('🔄 Compensação — sagaId:', body.sagaId, '| actions:', body.compensationActions);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/process/process-order",
          "host": ["{{baseUrl}}"],
          "path": ["process", "process-order"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": {\n    \"customerId\": \"1001\",\n    \"name\": \"Joao Silva\",\n    \"email\": \"joao@email.com\",\n    \"document\": \"12345678900\"\n  },\n  \"order\": {\n    \"item\": \"Laptop\",\n    \"qty\": 1,\n    \"unitPrice\": 2599.99,\n    \"totalAmount\": 2599.99\n  },\n  \"billing\": {\n    \"paymentMethod\": \"CREDIT_CARD\",\n    \"cardToken\": \"tok_1234567890\"\n  },\n  \"shipping\": {\n    \"address\": \"Rua das Flores, 123\",\n    \"city\": \"Sao Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01234-567\"\n  }\n}"
        }
      }
    },
    {
      "name": "03 — 400 Bad Request (payload inválido)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 400', () => pm.response.to.have.status(400));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('error = BAD_REQUEST', () => {",
              "    pm.expect(body.error).to.equal('BAD_REQUEST');",
              "});",
              "",
              "pm.test('message presente', () => {",
              "    pm.expect(body.message).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/process/process-order",
          "host": ["{{baseUrl}}"],
          "path": ["process", "process-order"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": {}\n}"
        }
      }
    },
    {
      "name": "04 — GET Saga Status (usa sagaId do request anterior)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const sagaId = pm.collectionVariables.get('sagaId');",
              "if (!sagaId) {",
              "    console.warn('⚠️  sagaId não definido. Execute o request 01 ou 02 primeiro.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200 ou 404', () => {",
              "    pm.expect([200, 404]).to.include(pm.response.code);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "if (pm.response.code === 200) {",
              "    pm.test('sagaId presente no estado', () => {",
              "        pm.expect(body.sagaId).to.be.a('string').and.not.empty;",
              "    });",
              "",
              "    pm.test('status é um valor válido', () => {",
              "        const validStatuses = ['STARTED','PEDIDO_COMPLETED','ESTOQUE_COMPLETED','FATURA_COMPLETED','COMPLETED','COMPENSATED'];",
              "        pm.expect(validStatuses).to.include(body.status);",
              "    });",
              "    console.log('📋 Saga status:', body.status, '| lastStep:', body.lastCompletedStep);",
              "} else {",
              "    pm.test('error = SAGA_NOT_FOUND', () => {",
              "        pm.expect(body.error).to.equal('SAGA_NOT_FOUND');",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/process/saga-status/{{sagaId}}",
          "host": ["{{baseUrl}}"],
          "path": ["process", "saga-status", "{{sagaId}}"]
        }
      }
    }
  ]
}
